# CPL Server Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# JWT Secret (generate a strong random string)
CPL_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
CPL_GITHUB_CLIENT_ID=your-github-oauth-app-client-id
CPL_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Admin GitHub IDs (comma-separated list of GitHub numeric user IDs)
# These users can moderate comments
CPL_ADMIN_GITHUB_IDS=123456,789012

# JWT Token Expiry (in days)
CPL_JWT_EXPIRY_DAYS=30

# Comment Rate Limit (comments per hour per user)
CPL_COMMENT_RATE_LIMIT=10
