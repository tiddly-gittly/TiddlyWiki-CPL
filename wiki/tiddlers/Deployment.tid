│       ├── index.ts           # Plugin index
│       ├── install.ts         # Plugin installation
│       ├── update.ts          # Update checking
├── background-actions/        # Wikitext BackgroundAction tiddlers
│   ├── auto-submit-rating.tid
│   ├── auto-submit-comment.tid
│   ├── auto-submit-compatibility.tid
│   ├── auto-moderate-comment.tid
│   ├── auto-moderate-compatibility.tid
│   ├── auto-logout.tid
│   ├── auto-record-download.tid
│   ├── auto-api-get-stats.tid
│   ├── auto-api-record-download.tid
│   ├── auto-probe-server.tid
│   ├── auto-fetch-auth-state.tid
│   ├── auto-fetch-comments.tid
│   ├── auto-sync-server-config.tid
