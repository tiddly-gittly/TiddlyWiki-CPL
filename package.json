{
  "name": "tiddlywiki-cpl",
  "version": "1.0.0",
  "description": "TiddlyWiki5 Plugin Library for TiddlyWiki Chinese Communities",
  "main": "scripts/index.ts",
  "scripts": {
    "help": "ts-node --transpile-only scripts help",
    "clean": "rimraf ./dist ./cache",
    "dev": "tiddlywiki-plugin-dev dev --wiki wiki",
    "dev:lan": "tiddlywiki-plugin-dev dev --wiki wiki --lan",
    "dev:wiki": "tiddlywiki-plugin-dev dev --wiki wiki --write-wiki",
    "build": "tiddlywiki-plugin-dev build --wiki wiki",
    "build:static-site": "ts-node --transpile-only scripts/build-static-site.ts",
    "build:static-library": "ts-node --transpile-only scripts/build-static-library.ts",
    "import:libraries": "ts-node --transpile-only scripts/index.ts import library --all",
    "import:official-library": "ts-node --transpile-only scripts/index.ts import library --official",
    "server:test": "ts-node --transpile-only scripts/server.ts",
    "server:prod": "ts-node --transpile-only scripts/server.ts --prod",
    "fetch-plugins": "ts-node --transpile-only scripts/fetch-plugins.ts",
    "fetch-plugins:dry-run": "ts-node --transpile-only scripts/fetch-plugins.ts --dry-run",
    "reconcile-data": "ts-node --transpile-only scripts/reconcile-data.ts",
    "sync-data": "ts-node --transpile-only scripts/sync-data.ts",
    "lint": "eslint scripts src docker-entrypoint.ts --ext .js,.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:api": "jest tests/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiddly-gittly/TiddlyWiki-CPL.git"
  },
  "keywords": [
    "TiddlyWiki5",
    "PluginLibrary"
  ],
  "author": "Gk0Wk",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tiddly-gittly/TiddlyWiki-CPL/issues"
  },
  "engines": {
    "node": "24.x"
  },
  "homepage": "https://github.com/tiddly-gittly/TiddlyWiki-CPL#readme",
  "devDependencies": {
    "@modern-js/eslint-config": "^2.58.1",
    "@modern-js/tsconfig": "^2.58.1",
    "@playwright/test": "^1.40.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "fs-extra": "^11.2.0",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "tiddlywiki": "5.4.0",
    "tiddlywiki-plugin-dev": "^0.5.8",
    "ts-node": "^10.9.2",
    "tw5-typed": "0.5.14",
    "typescript": "^5.1.6",
    "workbox-cli": "7.1.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.8",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0"
  }
}
