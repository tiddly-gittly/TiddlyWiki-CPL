{
  "name": "tiddlywiki-cpl",
  "version": "1.0.0",
  "description": "TiddlyWiki5 Plugin Library for TiddlyWiki Chinese Communities",
  "main": "scripts/index.js",
  "scripts": {
    "help": "ts-node scripts help",
    "server": "run start",
    "server:start": "node scripts/server.js",
    "server:prod": "node scripts/server.js --prod",
    "server:dev": "node scripts/server.js",
    "server:test": "node scripts/server.js",
    "clean": "rimraf ./dist ./cache",
    "start": "tiddlywiki +plugins/tiddlywiki/filesystem +plugins/tiddlywiki/tiddlyweb wiki --listen port=8080",
    "dev": "tiddlywiki-plugin-dev dev --wiki wiki",
    "dev:lan": "tiddlywiki-plugin-dev dev --wiki wiki --lan",
    "dev:wiki": "tiddlywiki-plugin-dev dev --wiki wiki --write-wiki",
    "build": "tiddlywiki-plugin-dev build --wiki wiki",
    "build:library": "tiddlywiki-plugin-dev build --library --wiki wiki --output dist/library",
    "dev:build": "npm run clean && cross-env NODE_ENV=development npm run build",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:api": "jest tests/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiddly-gittly/TiddlyWiki-CPL.git"
  },
  "keywords": [
    "TiddlyWiki5",
    "PluginLibrary"
  ],
  "author": "Gk0Wk",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tiddly-gittly/TiddlyWiki-CPL/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "homepage": "https://github.com/tiddly-gittly/TiddlyWiki-CPL#readme",
  "devDependencies": {
    "@modern-js/eslint-config": "^2.58.1",
    "@modern-js/tsconfig": "^2.58.1",
    "@playwright/test": "^1.40.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.4.1",
    "cross-env": "^7.0.3",
    "fs-extra": "^11.2.0",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "tiddlywiki": "5.3.6",
    "tiddlywiki-plugin-dev": "^0.5.8",
    "ts-node": "^10.9.2",
    "tw5-typed": "0.5.14",
    "workbox-cli": "7.1.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.8",
    "chalk": "^4.1.2",
    "commander": "^12.1.0"
  }
}
